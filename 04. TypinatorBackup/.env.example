# Copy this file to .env and adjust to match your setup.
# .env is gitignored so each machine can have its own values.
# The script uses the values below as defaults if .env is absent.

# Path inside "My Drive/" on Google Drive where backups are stored.
DRIVE_SUBPATH="08. Software/01. OSX macOS/05. Typinator"

# Name of the archive subfolder inside DRIVE_SUBPATH.
ARCHIVE_SUBDIR="90. Backups"

# How many days of dated archive folders to keep in ARCHIVE_SUBDIR.
MAX_DAYS=7

# Where Typinator stores your sets — leave commented out unless yours differs.
# TYPINATOR_SETS="$HOME/Library/Application Support/Typinator/Sets"
